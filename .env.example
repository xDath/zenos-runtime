# Required authentication. Configure at least one; production fails closed.
ZENOS_RUNTIME_API_KEY=replace-with-a-long-random-secret
ETLA_MASTER_SECRET=replace-with-a-separate-long-random-secret

# OpenAI-compatible router used by all role slots unless a per-role URL is configured.
ZENOS_LLM_BASE_URL=http://127.0.0.1:20128/model
ZENOS_LLM_API_KEY=

# Preserve the current Zenos defaults unless intentionally changed.
ZENOS_HOST_MODEL=grok
ZENOS_WORKER_MODEL=build
ZENOS_BOSS_MODEL=codex
ZENOS_VERIFIER_MODEL=grok

# Optional provider labels shown in runtime diagnostics.
ZENOS_HOST_PROVIDER=etla-router
ZENOS_WORKER_PROVIDER=etla-router
ZENOS_BOSS_PROVIDER=etla-router
ZENOS_VERIFIER_PROVIDER=etla-router

# Durable state. The systemd unit uses /var/lib/zenos-runtime/runtime.db.
ZENOS_RUNTIME_DB_PATH=.data/runtime.db
ZENOS_RUNTIME_CONFIG_PATH=.data/models.json
ZENOS_RUNTIME_SESSION_MODEL_DIR=.data/runtime-session-models

# Security and operational policy.
ZENOS_ALLOW_LEGACY_HMAC=false
ZENOS_HMAC_MAX_SKEW_MS=90000
ZENOS_MODEL_TIMEOUT_MS=90000
# Internal backend turns for unfinished coding validation; hard-bounded to 1..5.
ZENOS_GATEWAY_MAX_AUTO_CONTINUATIONS=5
ZENOS_LOG_LEVEL=info
ZENOS_BIND_HOST=127.0.0.1
PORT=3090

# Optional Zenos Memory integration.
ZENOS_MEMORY_BASE_URL=https://zenos-memory.vercel.app
ZENOS_MEMORY_NAMESPACE=zenos
ZENOS_MEMORY_API_KEY=
ZENOS_RUNTIME_DISABLE_MEMORY=false
ZENOS_RUNTIME_DISABLE_MEMORY_AUTO_RECALL=false
